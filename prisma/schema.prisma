generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
}

model Game {
  id          String   @id @default(cuid())
  key         String   @unique   // Uppercase slug: "SNAKE", "SNAKE_VS_SNAKE"
  name        String
  description String   @default("")
  color       String
  route       String
  badge       String
  emoji       String   @default("")
  isActive    Boolean  @default(true)
  showInNav   Boolean  @default(false)
  createdAt   DateTime @default(now())

  scores Score[]
  rooms  GameRoom[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  username     String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  scores       Score[]
  gamePlayers  GamePlayer[]
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  value     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id])

  @@index([gameId, value(sort: Desc)])
}

model GameRoom {
  id        String     @id @default(cuid())
  gameId    String
  status    RoomStatus @default(WAITING)
  hostId    String
  state     Json       @default("{}")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  game      Game       @relation(fields: [gameId], references: [id])
  players   GamePlayer[]
}

model GamePlayer {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  playerSlot Int
  joinedAt   DateTime @default(now())
  room       GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@unique([roomId, playerSlot])
}
